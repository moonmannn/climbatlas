# Optional: make the homepage feedback button open an external form.
# Example: https://forms.gle/your-form-id or https://tally.so/r/your-form-id
# Leave blank to use the built-in /feedback page.
NEXT_PUBLIC_FEEDBACK_URL=

# Optional: make the built-in /feedback page open an email draft.
NEXT_PUBLIC_FEEDBACK_EMAIL=thz923@qq.com

# Supabase V3 personal route notebook.
# Create a Supabase project, run supabase/schema.sql, then copy these values
# from Project Settings > API.
# Never commit real Supabase keys in .env.example or GitHub.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
